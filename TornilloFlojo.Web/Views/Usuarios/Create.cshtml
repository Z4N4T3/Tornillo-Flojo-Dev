@model TornilloFlojo.Web.Models.UsuarioCreateViewModel
@{
    ViewData["Title"] = "Crear Nuevo Usuario";
    Layout = "_AdminLayout";
}

<div class="mb-4 d-flex justify-content-between align-items-center">
    <div>
        <h1 class="h3 fw-bold mb-1">Crear Nuevo Usuario</h1>
        <p class="text-muted mb-0">Agrega un empleado al sistema y configura sus credenciales de acceso.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Volver
    </a>
</div>

<div class="card border shadow-sm">
    <div class="card-body p-4">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-4"></div>

            <!-- ── Sección 1: Información Personal ─────────────────────── -->
            <h6 class="fw-bold text-uppercase text-muted mb-3 d-flex align-items-center gap-2" style="font-size:.75rem; letter-spacing:.08em;">
                <i class="bi bi-person-fill text-warning"></i> Información Personal
            </h6>
            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <label asp-for="Nombre1" class="form-label small fw-semibold">Primer Nombre *</label>
                    <input asp-for="Nombre1" class="form-control" placeholder="Ej. Juan" />
                    <span asp-validation-for="Nombre1" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Nombre2" class="form-label small fw-semibold">Segundo Nombre</label>
                    <input asp-for="Nombre2" class="form-control" placeholder="Ej. Carlos" />
                </div>
                <div class="col-md-3">
                    <label asp-for="Apellido1" class="form-label small fw-semibold">Primer Apellido *</label>
                    <input asp-for="Apellido1" class="form-control" placeholder="Ej. Pérez" />
                    <span asp-validation-for="Apellido1" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Apellido2" class="form-label small fw-semibold">Segundo Apellido</label>
                    <input asp-for="Apellido2" class="form-control" placeholder="Ej. García" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Identificacion" class="form-label small fw-semibold">Cédula / Identificación *</label>
                    <input asp-for="Identificacion" class="form-control" placeholder="000-000000-0000A" />
                    <span asp-validation-for="Identificacion" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="IdCargo" class="form-label small fw-semibold">Cargo *</label>
                    <select asp-for="IdCargo" asp-items="ViewBag.Cargos" class="form-select">
                        <option value="">— Seleccione un cargo —</option>
                    </select>
                    <span asp-validation-for="IdCargo" class="text-danger small"></span>
                </div>
            </div>

            <hr class="my-4" />

            <!-- ── Sección 2: Credenciales del Sistema ──────────────────── -->
            <h6 class="fw-bold text-uppercase text-muted mb-3 d-flex align-items-center gap-2" style="font-size:.75rem; letter-spacing:.08em;">
                <i class="bi bi-shield-lock-fill text-warning"></i> Credenciales de Acceso
            </h6>
            <div class="row g-3 mb-2">
                <div class="col-md-4">
                    <label asp-for="Username" class="form-label small fw-semibold">Nombre de Usuario *</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light"><i class="bi bi-at"></i></span>
                        <input asp-for="Username" class="form-control" placeholder="jperez" autocomplete="off" />
                    </div>
                    <span asp-validation-for="Username" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="PasswordTemporal" class="form-label small fw-semibold">Contraseña Temporal *</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light"><i class="bi bi-key"></i></span>
                        <input asp-for="PasswordTemporal" type="password" class="form-control" placeholder="••••••••" autocomplete="new-password" />
                    </div>
                    <div class="form-text">El usuario deberá cambiarla al primer inicio de sesión.</div>
                    <span asp-validation-for="PasswordTemporal" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="IdRol" class="form-label small fw-semibold">Rol del Sistema *</label>
                    <select asp-for="IdRol" asp-items="ViewBag.Roles" class="form-select">
                        <option value="">— Seleccione un rol —</option>
                    </select>
                    <span asp-validation-for="IdRol" class="text-danger small"></span>
                </div>
            </div>

            <div class="alert alert-warning py-2 mt-3 small d-flex align-items-center gap-2">
                <i class="bi bi-info-circle-fill"></i>
                <span>La contraseña se guardará como texto plano hasta que se implemente el módulo de hashing. No usar contraseñas reales de producción.</span>
            </div>

            <!-- ── Acciones del Formulario ───────────────────────────────── -->
            <div class="d-flex justify-content-end gap-3 pt-4 border-top mt-4">
                <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancelar</a>
                <button type="submit" class="btn btn-warning fw-bold px-4 text-dark">
                    <i class="bi bi-person-plus-fill me-2"></i>Guardar Usuario
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
