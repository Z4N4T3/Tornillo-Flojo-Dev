@{
    ViewData["Title"] = "Próximamente";
    Layout = "_AdminLayout";
}

<div class="d-flex flex-column align-items-center justify-content-center text-center" style="min-height: calc(100vh - 230px);">
    <div style="max-width: 480px;">
        <div class="mb-4">
            <i class="bi bi-cone-striped" style="font-size: 5rem; color: var(--gold);"></i>
        </div>
        <h2 class="fw-bold mb-3">Módulo en Desarrollo</h2>
        <p class="text-muted mb-4">
            Esta función está siendo construida y estará disponible próximamente.
            Mientras tanto, puedes seguir usando los módulos ya habilitados del sistema.
        </p>
        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-warning fw-bold text-dark px-4">
            <i class="bi bi-arrow-left me-2"></i>Volver al Dashboard
        </a>
    </div>
</div>
